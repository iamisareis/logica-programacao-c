#include <stdio.h>

int main() {
 float nota1, nota2, mf, media, examef;
 int presencialidade;
 
 printf("Digite a porcentagem de presencialidade: ");
 scanf("%d", &presencialidade);
 
 printf ("Digite a nota 1 do aluno: ");
 scanf("%f", &nota1);
 
 printf ("Digite a nota 2 do aluno: ");
 scanf("%f", &nota2);
 
 if (presencialidade >= 75){
     media = (nota1 + nota2)/2;
     printf("A média é de %.2f\n", media);
     
     if (media >= 7){
         printf("Aprovado!!");
     }else{
         printf("Digite a nota do exame final: ");
         scanf("%f", &examef);
         
         mf = (examef * 0.4) + (media * 0.6);
         if(mf >= 6){
             printf("Aprovado!");
         }else{
             printf("Reprovado!");
         }
     }
 }else{
     printf("Reprovado por falta!");
 }
 return 0;
}
