#include <stdio.h>

int main() {
    int num1, num2, maior, menor, diferença;
    
    printf("Digite o primeiro número: ");
    scanf("%d", &num1);
    printf("Digite o segundo número: ");
    scanf("%d", &num2);
    printf("==============================\n");
    
    if (num1 > num2){
        maior = num1;
        menor = num2;
    }
    else {
        maior = num2;
        menor = num1;
    }
    
    diferença = maior - menor;
    printf("O maior número digitado foi %d\n", maior);
    printf("O menor número digitado foi %d\n", menor);
    printf("A diferença entre os números foi de %d\n", diferença);
    return 0;
}
